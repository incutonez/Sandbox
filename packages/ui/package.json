    "@vueuse/core": "^14.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "client-zip": "^2.5.0",
    "glob": "^13.0.6",
    "highlight.js": "^11.11.1",
    "just-clone": "^6.2.0",
    "just-is-empty": "^3.4.1",
    "just-safe-get": "^4.2.0",
    "just-safe-set": "^4.2.1",
    "lodash-es": "^4.18.1",
    "mime-types": "^3.0.2",
    "papaparse": "^5.5.3",
    "path-browserify": "^1.0.1",
